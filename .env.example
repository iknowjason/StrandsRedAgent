# === Required (pick ONE provider) ===

# xAI Grok (default — least restrictive for red team ops)
XAI_API_KEY=xai-...

# OpenAI GPT (uncomment PROVIDER in client.py too)
# OPENAI_API_KEY=sk-...

# Anthropic Claude (uncomment PROVIDER in client.py too)
# ANTHROPIC_API_KEY=sk-ant-...

# === Optional (enable gated tools) ===

BRAVE_API_KEY=              # Enables brave_search OSINT
SERPER_API_KEY=             # Enables LinkedIn recon
